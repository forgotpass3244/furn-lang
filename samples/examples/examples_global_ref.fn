
# Example — referencing a global/static value (safe to hold longer)
# Globals live for the program duration, so pointers to them are long-lived.
var GLOBAL_VAL :: 777;

let global_ref_example :: ()
    var p *u64 :: &GLOBAL_VAL;   # allowed: GLOBAL_VAL is global
    print(**p);
end

public main :: ()
    global_ref_example()
end
