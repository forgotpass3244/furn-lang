
# My comment
#{
My
multi-line
comment
}

# a `let` binding allows the compiler to perform comptime optimizations like value inlining
var num u64 = 9;

let newline = () Rt::print_char(10);

public main = () {
    var x = 3;
    let px = &x;
    Rt::print_u64(*px);
    newline()
}
