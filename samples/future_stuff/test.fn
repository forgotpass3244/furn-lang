
# exported symbols get mangled to Pkgname?main
# additionally if the symbol is mutable
# it will begin with Pkgname$ instead of Pkgname?

# the runtime looks for the Main?main symbol
# so the package that contains the main function
# must also be named main

# the package statement can be anywhere
# since the symbol names are printed
# after generating IR
# so it will add the Pkgname?exportname
# after IR gen
# and non-exported globals will not be mangled
package Main;

# import system
# explicit 'package' keyword required after 'import'
# since i will add modules in the future that get lexed and parsed
# within the same file its imported into
import package TestPkg {
    myfunc() :: u64  # readonly
    var myvar u64    # mutable
}

# none of that has been implemented yet (TODO)

# return value is 10 since
# its last evaluated
# (blocks are expressions)
public main = () {
    {
        10
    }
}

